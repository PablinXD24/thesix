// --- FUNÇÃO DE SORTEIO DE NOVO ROUND ---
// Esta função integra a lógica de escolher o jogador, o alvo e o desafio
async function startNewRound(roomData) {
    const players = roomData.players;
    const activeIds = Object.keys(players).sort();
    
    // Define o próximo jogador da vez
    let nextIndex = 0;
    if(roomData.roundPlayer) {
        nextIndex = (activeIds.indexOf(roomData.roundPlayer) + 1) % activeIds.length;
    }
    const nextId = activeIds[nextIndex];
    const pData = players[nextId];

    // Sorteia um alvo (target) aleatório
    const otherPlayers = activeIds.filter(id => id !== nextId);
    const targetId = otherPlayers[Math.floor(Math.random() * otherPlayers.length)];
    const targetName = players[targetId].name.toUpperCase();

    let selectedChallenge = "";
    
    // Se o jogador tiver 3 ou mais strikes, o desafio é EXTREMO
    if ((pData.strikes || 0) >= 3) {
        selectedChallenge = extremeChallenges[Math.floor(Math.random() * extremeChallenges.length)];
    } else {
        selectedChallenge = challenges[Math.floor(Math.random() * challenges.length)];
    }

    // Processa a tag {target} no texto
    const finalChallengeText = selectedChallenge.replace(/{target}/g, targetName);

    // Atualiza no Firebase (exemplo de chamada)
    /* update(ref(db, `rooms/${roomCode}`), {
        nomercy_status: 'round',
        roundPlayer: nextId,
        roundPlayerName: pData.name,
        roundChallenge: finalChallengeText,
        roundTarget: selectedChallenge.includes("{target}") ? targetName : null
    });
    */
}
